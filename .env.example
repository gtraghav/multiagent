# ── LLM Gateway V3 — worker providers ────────────────────────────────────────
# Add keys for whichever providers you have. The gateway skips providers
# whose key is missing. At least one worker key is required.

GEMINI_API_KEY=your_gemini_key_here
# GEMINI_MODEL=gemini-2.5-flash          # default

GROQ_API_KEY=your_groq_key_here
# GROQ_MODEL=openai/gpt-oss-120b         # default

GITHUB_ACCESS_TOKEN=your_github_pat_here
# GITHUB_MODEL=openai/gpt-4.1-mini       # default

NVIDIA_API_KEY=your_nvidia_key_here
# NVIDIA_MODEL=deepseek-ai/deepseek-v3.2 # default

CEREBRAS_API_KEY=your_cerebras_key_here
# CEREBRAS_MODEL=zai-glm-4.7             # default; llama3.1-8b deprecates 2026-05-27

OPEN_ROUTER_API_KEY=your_openrouter_key_here
# OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free  # default

# OLLAMA_URL=http://localhost:11434       # only loaded if OLLAMA_MODEL is set
# OLLAMA_MODEL=gemma4:31b

ANTHROPIC_API_KEY=your_anthropic_key_here
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001   # default; swap for sonnet/opus for harder tasks
# ANTHROPIC_MODEL=claude-sonnet-4-6
# ANTHROPIC_MODEL=claude-opus-4-7

# ── LLM Gateway V3 — router pool ─────────────────────────────────────────────
# Router pool reuses the same provider keys above (no separate keys needed).
# Override router model selections only if the defaults are unavailable.

# ROUTER_CEREBRAS_MODEL=llama3.1-8b
# ROUTER_GROQ_MODEL=llama-3.3-70b-versatile
# ROUTER_NVIDIA_MODEL=nvidia/llama-3.1-nemotron-nano-8b-v1
# ROUTER_GITHUB_MODEL=microsoft/Phi-4-mini-instruct

# ── LLM Gateway V3 — ordering and port ───────────────────────────────────────
# LLM_ORDER=ollama,gemini,nvidia,groq,cerebras,openrouter,github
# ROUTER_ORDER=cerebras,groq,nvidia,github
# GATEWAY_V3_PORT=8101

# ── MCP server — web search ───────────────────────────────────────────────────
# Tavily is the primary search backend; DuckDuckGo is the automatic fallback
# if this key is missing or the monthly cap (950 calls) is reached.
TAVILY_API_KEY=your_tavily_key_here

# ── Agent ─────────────────────────────────────────────────────────────────────
# LLM_GATEWAY_V3_URL=http://localhost:8101   # default; change if gateway runs elsewhere
